{
  "name": "@diffusecraft/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index",
  "scripts": {
    "start": "expo start 2>&1 | tee /tmp/metro.log",
    "android": "expo run:android 2>&1 | tee /tmp/metro.log",
    "ios": "expo run:ios 2>&1 | tee /tmp/metro.log",
    "web": "expo start --web --port 8082 2>&1 | tee /tmp/metro-web.log",
    "start:raw": "expo start",
    "ios:raw": "expo run:ios",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@diffusecraft/ui": "workspace:*",
    "@expo/metro-runtime": "~55.0.10",
