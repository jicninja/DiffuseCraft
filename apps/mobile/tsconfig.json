{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "allowJs": true,
    "noEmit": true,
    "types": ["react-native", "node"]
  },
  "include": [
    "index.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts",
    "nativewind-env.d.ts",
    "app.config.ts"
  ],
  "exclude": ["node_modules", ".expo", "dist", "build"]
}
